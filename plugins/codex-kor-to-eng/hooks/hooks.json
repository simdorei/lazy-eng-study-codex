{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${PLUGIN_ROOT}/scripts/bootstrap.sh\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:PLUGIN_ROOT\\scripts\\bootstrap.ps1\"",
            "timeout": 240,
            "statusMessage": "Translating Korean prompt"
          }
        ]
      }
    ]
  }
}
